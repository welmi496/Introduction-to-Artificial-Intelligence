    print(avg_salary)
    print('\nEmployees with salary greater than 60000:')
    print(list(high_salary_names))
    print('\nEmployee DataFrame with Bonus column')
    print(df_employees)
except KeyError as e:
    print(f'Task 12 Error: Missing column - {e}')
except Exception as e:
    print(f'Task 12 Error: {e}')
