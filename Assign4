# Task 3: Handling Null Values
# Create a new DataFrame with some null values and fill them

try:
    df_null = pd.DataFrame({
        'Name': ['Anna', None, 'Chris', 'Diana'],
        'Age': [22, np.nan, 29, np.nan],
        'City': ['Ottawa', 'Toronto', None, 'Montreal']
    })
    print('\nTask 3: Original DataFrame with null values')
    print(df_null)

    # Method 1: Fill null values
    df_filled = df_null.copy()
    df_filled['Name'] = df_filled['Name'].fillna('Unknown')
    df_filled['Age'] = df_filled['Age'].fillna(0)
    df_filled['City'] = df_filled['City'].fillna('Not Provided')
    print('\nFilled DataFrame')
    print(df_filled)

    # Method 2: Drop rows with null values
    df_dropped = df_null.dropna()
    print('\nDataFrame after dropping rows with null values')
    print(df_dropped)
except Exception as e:
    print(f'Task 3 Error: {e}')


